{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vxbeamer",
  "version": "0.0.0",
  "identifier": "com.dtinth.vxbeamer.desktop",
  "build": {
    "beforeDevCommand": "node scripts/run-website-dev.mjs",
    "devUrl": "http://localhost:20470",
    "beforeBuildCommand": "node scripts/prepare-web-assets.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vxbeamer",
        "width": 480,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
