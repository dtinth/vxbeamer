{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vxbeamer Desktop",
  "version": "0.1.0",
  "identifier": "th.in.dt.vxbeamer.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm exec vp dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm exec vp build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vxbeamer Desktop",
        "width": 520,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
